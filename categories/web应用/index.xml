 &lt;a href="#%e9%a1%b9%e7%9b%ae%e6%88%aa%e5%9b%be"&gt;&lt;svg class="anchor-symbol" aria-hidden="true" height="26" width="26" viewBox="0 0 22 22" xmlns="http://www.w3.org/2000/svg"&gt;
